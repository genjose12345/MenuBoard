# Supabase — Project Settings → API
#
# IMPORTANT: use the Project URL (no path suffix), NOT the REST URL.
#   Correct:   https://your-project.supabase.co
#   Wrong:     https://your-project.supabase.co/rest/v1/
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-jwt-key

# Production site URL — used in confirmation email links (must match Supabase redirect URLs)
VITE_SITE_URL=https://your-app.vercel.app
